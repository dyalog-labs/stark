    в€‡ Start port;code;j
      :Access Public Instance
      '/openapi.json' Get '_OpenAPIHandler'
      codeв†ђвЋ•NS ''
      code.instв†ђвЋ•THIS
      code.Getв†ђ{inst._Dispatch вЌµ}
      code.Postв†ђ{inst._Dispatch вЌµ}
      code.Putв†ђ{inst._Dispatch вЌµ}
      code.Deleteв†ђ{inst._Dispatch вЌµ}
      code.Patchв†ђ{inst._Dispatch вЌµ}
      jв†ђвЋ•NEW #.Jarvis
      j.Portв†ђport
      j.Paradigmв†ђ'REST'
      j.CodeLocationв†ђcode
      j.RESTFailProcessingв†ђ1
      :If ''в‰ўThreadMode
          j.DYALOG_JARVIS_THREADв†ђThreadMode
