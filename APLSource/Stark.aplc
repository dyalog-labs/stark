    ‚ćĚ pattern pathMatch path ‚Üí (matched pathParams)
    pathMatch‚Üź{
        patSplit pathSplit‚Üź'/'(‚Č†‚äÜ‚äĘ)¬®‚ćļ ‚ćĶ
        pathSplit‚ČĘ‚ć•‚ČĘpatSplit:0()
        varMask‚Üź'{'=‚äÉ¬®patSplit
        ‚ČĘ/(‚äā~varMask)/¬®patSplit pathSplit:0()
        names‚Üź({1‚Üď¬Į1‚Üď‚ćĶ}¬®patSplit[‚ćłvarMask])
        1(()‚éēVSET‚Üď‚ćČ‚ÜĎnames(pathSplit[‚ćłvarMask]))
