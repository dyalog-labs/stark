:Class ConceptApp
‚çù Concept: executable decorator syntax for OpenAPI spec generation.
‚çù
‚çù Each ‚çù@ block is valid APL stripped of its ‚çù@  prefixes and eval'd.
‚çù The call registers the route; the ‚àá that follows provides the handler.
‚çù
‚çù   ‚çù@ app.Get(path: '/items/{item_id}')          ‚Üê minimal, one line
‚çù
‚çù   ‚çù@ app.Post(                                   ‚Üê with metadata
‚çù   ‚çù@   path:    '/items'
‚çù   ‚çù@   summary: 'Create item'
‚çù   ‚çù@   ...
‚çù   ‚çù@ )                                           ‚Üê closing ) ends the decorator
‚çù   ‚àá handler req                                  ‚Üê ‚àá begins the function
‚çù
‚çù HTTP verb is the method name: app.Get  app.Post  app.Put  app.Delete  app.Patch
‚çù Schema names (e.g. 'Item') are resolved against public :fields on this class.

    :field private app

    ‚çù ‚îÄ‚îÄ Schemas ‚îÄ‚îÄ named fields; referenced by string in metadata ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

    :field public Item‚Üê(
      type: 'object'
      properties: (
        id:    (type: 'integer')
        name:  (type: 'string')
        price: (type: 'number' ‚ãÑ format: 'float')
        tags:  (type: 'array' ‚ãÑ items: (type: 'string'))
      )
      required: 'id' 'name' 'price'
    )

    :field public NewItem‚Üê(
      type: 'object'
      properties: (
        name:  (type: 'string')
        price: (type: 'number' ‚ãÑ format: 'float')
        tags:  (type: 'array' ‚ãÑ items: (type: 'string'))
      )
      required: 'name' 'price'
    )

    :field public Error‚Üê(
      type: 'object'
      properties: (detail: (type: 'string'))
    )

    ‚àá Make
      :Access Public
      :Implements constructor
      app‚Üê‚éïNEW ##.FastJarvis
      app.Handlers‚Üê‚éïTHIS
      app.OpenAPIInfo‚Üê(
        title:       'Item Catalog API'
        version:     '1.0.0'
        description: 'A demo catalog ‚Äî concept for executable decorator metadata'
      )
      ‚çù ‚éïSRC scan: collect consecutive ‚çù@ lines, strip prefix, eval each block,
      ‚çù then associate with the ‚àá function that immediately follows.
      app.Add¬®{...}‚éïSRC (‚äÉ‚àä‚éïCLASS ‚éïTHIS)
    ‚àá

    ‚àá Start port
      :Access Public
      app.Start port
    ‚àá


    ‚çù ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ items ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

    ‚çù@ app.Get(
    ‚çù@   path:        '/items'
    ‚çù@   summary:     'List all items'
    ‚çù@   description: 'Returns the catalog, optionally filtered by tag.'
    ‚çù@   tags:        ,'items'
    ‚çù@   params:      ‚äÇ(name: 'tag'  in: 'query'  required: 0  schema: (type: 'string'))
    ‚çù@   responses:   (200: (description: 'Array of items'  schema: (type: 'array' ‚ãÑ items: 'Item')))
    ‚çù@ )
    ‚àá result‚ÜêlistItems req;tag
      :Access Public
      tag‚Üêreq.QueryParams ‚éïVGET ‚äÇ'tag' ''
      result‚Üê(items: 'mock' 'data'  total: 2)
    ‚àá

    ‚çù@ app.Get(
    ‚çù@   path:      '/items/{item_id}'
    ‚çù@   summary:   'Get item by ID'
    ‚çù@   tags:      ,'items'
    ‚çù@   params:    ‚äÇ(name: 'item_id'  in: 'path'  required: 1  schema: (type: 'integer' ‚ãÑ minimum: 1))
    ‚çù@   responses: (
    ‚çù@     200: (description: 'The requested item'  schema: 'Item')
    ‚çù@     404: (description: 'Item not found'      schema: 'Error')
    ‚çù@   )
    ‚çù@ )
    ‚àá result‚ÜêgetItemById req
      :Access Public
      result‚Üê(id: req.PathParams.item_id  name: 'Mock item'  price: 9.99  tags: ,'general')
    ‚àá

    ‚çù@ app.Post(
    ‚çù@   path:      '/items'
    ‚çù@   summary:   'Create a new item'
    ‚çù@   tags:      ,'items'
    ‚çù@   body:      (required: 1  schema: 'NewItem')
    ‚çù@   responses: (
    ‚çù@     201: (description: 'Item created'     schema: 'Item')
    ‚çù@     422: (description: 'Validation error' schema: 'Error')
    ‚çù@   )
    ‚çù@ )
    ‚àá result‚ÜêcreateItem req;body
      :Access Public
      body‚Üêreq.Payload
      result‚Üê(id: 42  name: body.name  price: body.price  tags: ‚ç¨)
    ‚àá

    ‚çù@ app.Put(
    ‚çù@   path:      '/items/{item_id}'
    ‚çù@   summary:   'Replace an item'
    ‚çù@   tags:      ,'items'
    ‚çù@   params:    ‚äÇ(name: 'item_id'  in: 'path'  required: 1  schema: (type: 'integer'))
    ‚çù@   body:      (required: 1  schema: 'NewItem')
    ‚çù@   responses: (
    ‚çù@     200: (description: 'Updated item'    schema: 'Item')
    ‚çù@     404: (description: 'Item not found'  schema: 'Error')
    ‚çù@   )
    ‚çù@ )
    ‚àá result‚ÜêreplaceItem req;body
      :Access Public
      body‚Üêreq.Payload
      result‚Üê(id: req.PathParams.item_id  name: body.name  price: body.price  tags: ‚ç¨)
    ‚àá

    ‚çù@ app.Delete(
    ‚çù@   path:       '/items/{item_id}'
    ‚çù@   summary:    'Delete an item'
    ‚çù@   tags:       ,'items'
    ‚çù@   deprecated: 1
    ‚çù@   params:     ‚äÇ(name: 'item_id'  in: 'path'  required: 1  schema: (type: 'integer'))
    ‚çù@   responses:  (
    ‚çù@     204: (description: 'Deleted successfully')
    ‚çù@     404: (description: 'Item not found'  schema: 'Error')
    ‚çù@   )
    ‚çù@ )
    ‚àá result‚ÜêdeleteItem req
      :Access Public
      result‚Üê(deleted: 1  id: req.PathParams.item_id)
    ‚àá


    ‚çù ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ search ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

    ‚çù@ app.Get(
    ‚çù@   path:        '/search'
    ‚çù@   summary:     'Full-text search across the catalog'
    ‚çù@   tags:        ,'search'
    ‚çù@   params:      (
    ‚çù@     (name: 'q'       in: 'query'  required: 1  schema: (type: 'string')                        description: 'Search query')
    ‚çù@     (name: 'limit'   in: 'query'  required: 0  schema: (type: 'integer' ‚ãÑ default: 20 ‚ãÑ max: 100) description: 'Max results')
    ‚çù@     (name: 'offset'  in: 'query'  required: 0  schema: (type: 'integer' ‚ãÑ default: 0)          description: 'Pagination offset')
    ‚çù@   )
    ‚çù@   responses:   (
    ‚çù@     200: (description: 'Matching items'  schema: (type: 'array' ‚ãÑ items: 'Item'))
    ‚çù@     400: (description: 'Missing query'   schema: 'Error')
    ‚çù@   )
    ‚çù@ )
    ‚àá result‚ÜêsearchItems req;q;limit;offset
      :Access Public
      q‚Üêreq.QueryParams ‚éïVGET ‚äÇ'q' ''
      limit‚Üêreq.QueryParams ‚éïVGET ‚äÇ'limit' 20
      offset‚Üêreq.QueryParams ‚éïVGET ‚äÇ'offset' 0
      result‚Üê(query: q  results: 'mock' 'data'  total: 2)
    ‚àá


    ‚çù ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ meta ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

    ‚çù@ app.Get(path: '/openapi.json'  summary: 'OpenAPI specification'  tags: ,'meta')
    ‚àá result‚ÜêgetOpenAPISpec req
      :Access Public
      result‚Üêapp.GenerateOpenAPISpec
    ‚àá

:EndClass
