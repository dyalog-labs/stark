#!/usr/bin/dyalogscript

вЋ•IOв†ђ1
вЋ•SE.(вЌЋвЉѓ2вЋ•FIX'/StartupSession.aplf',вЌЁ2вЋ•NQ#'GetEnvironment' 'DYALOG')

вЋ•SE.Link.Import '#' './APLSource'

вЌќ в”Ђв”Ђ Test harness в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
passв†ђfailв†ђ0

Assertв†ђ{
    вЌєв†ђ'assertion'
    вЌµ:pass+в†ђ1
    fail+в†ђ1
    вЋ•в†ђ'  FAIL: ',вЌє
    0
}

Sectionв†ђ{вЋ•в†ђ'' в‹„ вЋ•в†ђ'в”Ђв”Ђ ',вЌµ,' ',((60-в‰ўвЌµ)вЌґ'в”Ђ')}

вЌќ в”Ђв”Ђ 1. Router construction & route registration в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
Section 'Route Registration'

routerв†ђвЋ•NEW #.Router
handlersв†ђвЋ•NS ''
handlers.Pingв†ђ{'pong'}
handlers.GetUserв†ђ{(id: вЌµ.PathParams.id)}
handlers.CreateUserв†ђ{(created: 1)}
router.Handlersв†ђhandlers

'/ping'        router.Get  'Ping'
'/users/{id}'  router.Get  'GetUser'
'/users'       router.Post 'CreateUser'

routesв†ђrouter.Routes
'3 routes registered' Assert 3=в‰ўroutes
'route 1 is GET'      Assert 'GET'в‰Ў(вЉѓroutes).method
'route 1 pattern'     Assert '/ping'в‰Ў(вЉѓroutes).pattern
'route 1 handler'     Assert 'Ping'в‰Ў(вЉѓroutes).handler
'route 2 is GET'      Assert 'GET'в‰Ў(2вЉѓroutes).method
'route 3 is POST'     Assert 'POST'в‰Ў(3вЉѓroutes).method

вЌќ в”Ђв”Ђ 2. Registration with metadata в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
Section 'Metadata Registration'

router2в†ђвЋ•NEW #.Router
router2.Handlersв†ђhandlers
optsв†ђ(summary: 'Create a user' в‹„ tags: 'users')
'/users' router2.Post ('CreateUser' opts)

rв†ђвЉѓrouter2.Routes
'options stored'    Assert 9в‰¤вЋ•NC'r.options'
'summary in opts'   Assert 'Create a user'в‰Ўr.options.summary
'tags in opts'      Assert 'users'в‰Ўr.options.tags

вЌќ в”Ђв”Ђ 3. Path matching в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
Section 'Path Matching'

MockReqв†ђ{
    rв†ђвЋ•NS ''
    r.Methodв†ђвЌє
    r.Endpointв†ђвЌµ
    r.Payloadв†ђвЋ•NS ''
    r.QueryParamsв†ђ0 2вЌґ''
    r.Headersв†ђвЋ•NS ''
    r.StatusCodeв†ђ200
    r.Failв†ђ{вЌµ}
    r
}

resultв†ђrouter._Dispatch ('GET' MockReq '/ping')
'GET /ping returns pong' Assert 'pong'в‰Ўresult

resultв†ђrouter._Dispatch ('GET' MockReq '/users/42')
'GET /users/42 id' Assert '42'в‰Ўresult.id

resultв†ђrouter._Dispatch ('POST' MockReq '/users')
'POST /users created' Assert 1в‰Ўresult.created

resultв†ђrouter._Dispatch ('GET' MockReq '/nonexistent')
'404 detail' Assert 'Not Found'в‰Ўresult.detail

вЌќ в”Ђв”Ђ 4. Case-insensitive method matching в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
Section 'Case Insensitive Methods'

resultв†ђrouter._Dispatch ('get' MockReq '/ping')
'lowercase get works' Assert 'pong'в‰Ўresult

вЌќ в”Ђв”Ђ 5. Multi-segment path params в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
Section 'Multi-Segment Params'

router3в†ђвЋ•NEW #.Router
router3.Handlersв†ђвЋ•NS ''
router3.Handlers.GetInvoiceв†ђ{(cust: вЌµ.PathParams.cust_id в‹„ inv: вЌµ.PathParams.inv_id)}
'/customer/{cust_id}/invoice/{inv_id}' router3.Get 'GetInvoice'

resultв†ђrouter3._Dispatch ('GET' MockReq '/customer/42/invoice/99')
'multi param cust' Assert '42'в‰Ўresult.cust
'multi param inv'  Assert '99'в‰Ўresult.inv

вЌќ в”Ђв”Ђ 6. ExampleApp construction в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
Section 'ExampleApp'

appв†ђвЋ•NEW #.ExampleApp
rв†ђapp.GetRouter
'app has routes' Assert 0<в‰ўr.Routes
вЋ•в†ђ'  ExampleApp created with ',(вЌ•в‰ўr.Routes),' routes'

вЌќ в”Ђв”Ђ 7. Integration: actual Jarvis server в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
Section 'Integration (Jarvis)'

portв†ђ8899
app.Start port
вЋ•DL 1

baseв†ђ'http://localhost:',вЌ•port

вЌќ GET /
rв†ђ#.HttpCommand.Get (base,'/')
'GET / status 200'    Assert 200=r.HttpStatus
'GET / has status ok' Assert в€Ё/'ok'вЌ·r.Data
вЋ•в†ђ'  GET / в†’ ',вЌ•r.HttpStatus

вЌќ GET /items
rв†ђ#.HttpCommand.Get (base,'/items')
'GET /items 200'      Assert 200=r.HttpStatus
вЋ•в†ђ'  GET /items в†’ ',вЌ•r.HttpStatus

вЌќ GET /items/1
rв†ђ#.HttpCommand.Get (base,'/items/1')
'GET /items/1 200'    Assert 200=r.HttpStatus
'GET /items/1 name'   Assert в€Ё/'Dyalog APL'вЌ·r.Data
вЋ•в†ђ'  GET /items/1 в†’ ',вЌ•r.HttpStatus

вЌќ GET /items/999 (not found)
rв†ђ#.HttpCommand.Get (base,'/items/999')
'GET /items/999 404'  Assert 404=r.HttpStatus
вЋ•в†ђ'  GET /items/999 в†’ ',вЌ•r.HttpStatus

вЌќ POST /items
rв†ђ#.HttpCommand.Do 'POST' (base,'/items') '{"name":"Test Item","price":42}'
'POST /items status'  Assert r.HttpStatusв€Љ200 201
'POST /items name'    Assert в€Ё/'Test Item'вЌ·r.Data
вЋ•в†ђ'  POST /items в†’ ',вЌ•r.HttpStatus

вЌќ GET /search?q=hello
rв†ђ#.HttpCommand.Get (base,'/search?q=hello')
'GET /search 200'     Assert 200=r.HttpStatus
'GET /search query'   Assert в€Ё/'hello'вЌ·r.Data
вЋ•в†ђ'  GET /search?q=hello в†’ ',вЌ•r.HttpStatus

вЌќ GET /customer/42/invoice/99
rв†ђ#.HttpCommand.Get (base,'/customer/42/invoice/99')
'GET invoice 200'     Assert 200=r.HttpStatus
'GET invoice cust'    Assert в€Ё/'42'вЌ·r.Data
'GET invoice inv'     Assert в€Ё/'99'вЌ·r.Data
вЋ•в†ђ'  GET /customer/42/invoice/99 в†’ ',вЌ•r.HttpStatus

вЌќ 404 on unknown route
rв†ђ#.HttpCommand.Get (base,'/nonexistent')
'unknown route 404'   Assert 404=r.HttpStatus
вЋ•в†ђ'  GET /nonexistent в†’ ',вЌ•r.HttpStatus

app.Stop

вЌќ в”Ђв”Ђ Summary в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
вЋ•в†ђ''
вЋ•в†ђ'в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ'
вЋ•в†ђ'  Passed: ',вЌ•pass
вЋ•в†ђ'  Failed: ',вЌ•fail
вЋ•в†ђ'в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ'
:If fail>0 в‹„ вЋ•OFF 1 в‹„ :EndIf
